{
    "name": "tu-nombre/taller-pro",
    "description": "Sistema de gestión para taller multiservicio con arquitectura MVC",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Tu Nombre",
            "email": "tu@email.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^3.1",
        "phpmailer/phpmailer": "^6.8",
        "chillerlan/php-qrcode": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
